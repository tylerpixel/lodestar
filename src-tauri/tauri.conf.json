{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lodestar",
  "version": "0.2.2",
  "identifier": "com.tylerpixel.lodestar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lodestar",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyMzU0Q0M3Mjc4ODBFM0MKUldROERvZ254MHcxZ3IxWVB3cTVOdUxQVHpSS1JPRklWZ2JOaVV4Ymt4RGw0U0tCeTFTSDdMaFUK",
      "endpoints": [
        "https://github.com/tylerpixel/lodestar/releases/latest/download/latest.json"
      ]
    }
  }
}
